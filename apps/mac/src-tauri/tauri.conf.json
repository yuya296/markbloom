{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkBloom",
  "version": "0.1.0",
  "identifier": "io.github.yuya296.markbloom",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MarkBloom",
        "width": 1120,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "createUpdaterArtifacts": false
  }
}
